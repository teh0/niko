# ─── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://niko:niko@localhost:5432/niko?schema=public"

# ─── Redis (BullMQ) ────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── GitHub App ────────────────────────────────────────────
# Create at https://github.com/settings/apps/new
# Permissions: Contents (R/W), Pull requests (R/W), Metadata (R), Webhooks (R/W)
# Events: Pull request, Pull request review, Push, Issue comment
GITHUB_APP_ID=""
GITHUB_APP_PRIVATE_KEY=""         # PEM, with newlines as \n OR raw with quotes
GITHUB_APP_CLIENT_ID=""
GITHUB_APP_CLIENT_SECRET=""
GITHUB_WEBHOOK_SECRET=""          # random string, same in GitHub App settings

# Optional fallback: Personal Access Token (fine-grained)
# Only used if GITHUB_APP_ID is not set
GITHUB_PAT=""

# ─── Claude MAX ────────────────────────────────────────────
# No API key needed — the orchestrator spawns the `claude` CLI
# which must be authenticated once via `claude login` on the host.
# Path to the claude CLI binary (autodetected if in PATH):
CLAUDE_CLI_PATH="claude"

# Optional: override the ~/.claude directory path
# (useful to isolate studio credentials from your personal ones)
CLAUDE_HOME=""

# ─── Figma MCP (optional) ──────────────────────────────────
# Gives agents read access to Figma mockups via the figma-context-mcp server.
# https://github.com/GLips/Figma-Context-MCP
# Create a Figma personal access token at https://www.figma.com/developers/api#access-tokens
FIGMA_API_KEY=""

# ─── Studio ────────────────────────────────────────────────
# Root where agents clone project repos.
#
# STRICTLY SEPARATED FROM THE STUDIO SOURCE CODE: never point this inside
# the niko repo itself. Each project lives in its own subdirectory
# `${WORKSPACE_DIR}/<projectId>/` and agents operate with their cwd
# pinned to that subdirectory. The studio's own code is NEVER visible
# to agents (they can't read this repo).
WORKSPACE_DIR="/var/lib/niko/workspaces"

# Public URL of this studio (for GitHub webhooks)
PUBLIC_URL="http://localhost:3000"

# Max concurrent agent runs (mind your Claude MAX rate limits)
MAX_CONCURRENT_AGENTS=4

# Optional fallback when MAX is rate-limited. If set, the runtime uses the
# API key instead of the MAX OAuth session. Leave empty to stay 100% on MAX.
ANTHROPIC_API_KEY=""

# How long (minutes) to keep the queue paused after a 429 from Claude.
# The CLI doesn't always return retry-after; 60min is a safe default that
# matches the MAX 5-hour rolling window.
RATE_LIMIT_PAUSE_MINUTES=60
