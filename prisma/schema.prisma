// Niko — AI studio data model
// Represents projects, the agent team working on them, validation gates,
// tickets, PRs, and every agent execution (for observability + replay).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Projects ────────────────────────────────────────────────────────────

model Project {
  id            String   @id @default(cuid())
  name          String
  brief         String   @db.Text          // structured brief produced by the Intake agent
  intakeSession IntakeSession?
  githubOwner   String                     // e.g. "les-ignobles"
  githubRepo    String                     // e.g. "my-app"
  installationId BigInt?                   // GitHub App installation id (null if PAT)
  defaultBranch String   @default("main")

  // Optional Figma file URL. When set, UI-facing agents (PM, Dev Web, Dev
  // Mobile) are told to consult the designs via the Figma MCP tools.
  figmaUrl      String?

  // Stack plan — decided by Tech Lead at project kickoff, validated by user.
  // null until the Tech Lead gate is approved.
  stackPlan     Json?

  status        ProjectStatus @default(INTAKE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  gates         Gate[]
  tickets       Ticket[]
  agentRuns     AgentRun[]
  pullRequests  PullRequest[]
  pmMessages    ProjectMessage[]

  @@unique([githubOwner, githubRepo])
}

/// Ongoing conversation with the PM agent about this project — add
/// features, ask questions, get help crafting tickets mid-flight.
model ProjectMessage {
  id        String     @id @default(cuid())
  projectId String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  role      ProjectMsgRole
  content   String     @db.Text

  // If the PM's message caused tickets to be created, we list their ids
  // so the UI can show an inline "N tickets created" affordance.
  createdTicketIds String[] @default([])

  createdAt DateTime   @default(now())

  @@index([projectId, createdAt])
}

enum ProjectMsgRole {
  USER
  AGENT
  SYSTEM
}

enum ProjectStatus {
  INTAKE            // brief just received
  SPECCING          // PM writing specs
  STACK_PLANNING    // Tech Lead proposing stack
  SCAFFOLDING       // Tech Lead scaffolding repo
  BUILDING          // devs working
  QA                // QA review in progress
  READY             // all gates approved, ready to hand off
  PAUSED            // blocked waiting on user
  FAILED            // terminal error
}

// ─── Validation gates (human-in-the-loop decisions) ──────────────────────

model Gate {
  id          String      @id @default(cuid())
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  kind        GateKind
  title       String
  description String      @db.Text

  // GitHub PR where the user reviews/approves this gate.
  // For non-code gates (e.g. specs), we still open a PR with the doc.
  prNumber    Int?
  prUrl       String?

  status      GateStatus  @default(PENDING)
  decision    GateDecision?
  feedback    String?     @db.Text         // user comment on rejection/changes
  decidedAt   DateTime?
  decidedBy   String?                      // github login of reviewer

  messages    GateMessage[]                // user↔agent conversation about this gate

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([projectId, status])
}

// Multi-turn discussion on a gate — user asks questions, agent (the one who
// produced the gate) answers. Runs read-only; approving is still a separate
// decision made via the UI buttons or a GitHub PR review.
model GateMessage {
  id        String       @id @default(cuid())
  gateId    String
  gate      Gate         @relation(fields: [gateId], references: [id], onDelete: Cascade)

  role      GateMsgRole
  content   String       @db.Text

  createdAt DateTime     @default(now())

  @@index([gateId, createdAt])
}

enum GateMsgRole {
  USER
  AGENT
  SYSTEM
}

enum GateKind {
  SPECS              // PM's specs doc
  STACK_PLAN         // Tech Lead's ADR on stack
  DATA_MODEL         // DB Expert's schema
  SCAFFOLD           // initial repo scaffold
  FEATURE_PR         // each dev PR
  RED_TEAM_REVIEW    // Red Team QA report on a feature PR
  STUCK_DIAGNOSTIC   // Debug agent's root-cause report on a stuck ticket
  QA_SIGNOFF         // QA final approval
  RELEASE            // final release readiness
}

enum GateStatus {
  PENDING
  DECIDED
}

enum GateDecision {
  APPROVED
  CHANGES_REQUESTED
  REJECTED
}

// ─── Tickets (unit of work) ──────────────────────────────────────────────

model Ticket {
  id           String      @id @default(cuid())
  projectId    String
  project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title        String
  description  String      @db.Text
  role         AgentRole                   // which agent owns this ticket
  priority     Int         @default(0)
  status       TicketStatus @default(TODO)
  dependsOn    String[]                    // ticket ids
  prNumber     Int?
  branch       String?

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  agentRuns    AgentRun[]

  @@index([projectId, status])
}

enum TicketStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  CHANGES_REQUESTED
  DONE
  BLOCKED
}

// ─── Agents ──────────────────────────────────────────────────────────────

enum AgentRole {
  PM                 // Product Manager
  TECH_LEAD          // Tech Lead
  DEV_WEB            // Next.js developer
  DEV_MOBILE         // Flutter developer
  DEV_BACKEND        // NestJS / backend developer
  DB_EXPERT          // Database engineer
  QA                 // QA engineer (happy path, spec compliance)
  RED_TEAM_QA        // Adversarial QA: tries to break the PR
  DEBUG              // Root-cause analysis when another agent gets stuck
  INTAKE             // Client Success: turns a fuzzy idea into a brief via chat
}

// Records every agent execution for observability, replay, audit.
model AgentRun {
  id          String     @id @default(cuid())
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ticketId    String?
  ticket      Ticket?    @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  role        AgentRole
  task        String                       // short description of what was asked
  input       Json                         // full input payload
  output      Json?                        // final structured output
  transcript  Json?                        // streamed messages from the agent (array)

  status      RunStatus  @default(QUEUED)
  error       String?    @db.Text
  startedAt   DateTime?
  endedAt     DateTime?
  tokensIn    Int?
  tokensOut   Int?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([projectId, role, status])
}

enum RunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

// ─── Intake (client discovery chat that produces the brief) ──────────────

model IntakeSession {
  id          String     @id @default(cuid())

  // Conversation state
  status      IntakeStatus @default(IN_PROGRESS)
  messages    IntakeMessage[]

  // Collected along the way (surfaced in the UI as the chat progresses)
  name        String?
  githubOwner String?
  githubRepo  String?
  installationId BigInt?
  figmaUrl    String?

  // Coverage checklist — which essentials have been addressed so far.
  // JSON keyed by slug with { done: boolean, note?: string }.
  coverage    Json?

  // Final structured brief (markdown) proposed by the agent and approved
  // by the user before project creation.
  finalBrief  String?    @db.Text

  // Once finalized → one Project is created and linked here.
  projectId   String?    @unique
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status])
}

enum IntakeStatus {
  IN_PROGRESS
  READY_TO_FINALIZE     // agent has proposed a brief; user can accept
  FINALIZED             // project created, flow started
  ABANDONED
}

model IntakeMessage {
  id        String         @id @default(cuid())
  sessionId String
  session   IntakeSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  role      IntakeRole
  content   String         @db.Text

  createdAt DateTime       @default(now())

  @@index([sessionId, createdAt])
}

enum IntakeRole {
  USER
  AGENT
  SYSTEM
}

// ─── Pull requests (mirrored from GitHub for quick queries) ──────────────

model PullRequest {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  number       Int
  title        String
  branch       String
  state        String                       // "open" | "closed" | "merged"
  merged       Boolean  @default(false)
  url          String
  openedByRole AgentRole?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([projectId, number])
}
