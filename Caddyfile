# Caddy config — automatic HTTPS + reverse proxy to the Next.js app.
# The DOMAIN env var is injected by docker-compose.
{
	email {$CADDY_EMAIL:admin@localhost}
}

{$DOMAIN} {
	encode zstd gzip

	# GitHub webhooks can be large; allow big payloads.
	request_body {
		max_size 10MB
	}

	# Health endpoint bypass (so uptime checks don't spam logs).
	handle /api/health {
		reverse_proxy web:3000
	}

	handle {
		reverse_proxy web:3000 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	log {
		output file /var/log/caddy/access.log {
			roll_size 10MB
			roll_keep 5
		}
	}
}
